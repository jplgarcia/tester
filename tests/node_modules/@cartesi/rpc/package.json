{
  "name": "@cartesi/rpc",
  "version": "2.0.0-alpha.20",
  "description": "Cartesi JSON-RPC Client",
  "repository": {
    "type": "git",
    "url": "https://github.com/cartesi/rollups-ts"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "json-rpc-2.0": "^1.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsup --watch",
    "lint": "biome check"
  }
}